{
  "name": "apex-protocol-tracker",
  "version": "1.0.0",
  "description": "Free peptide protocol tracker, encyclopedia, and stack analyzer",
  "private": true,
  "scripts": {
    "start": "python3 -m http.server 8080",
    "serve": "./serve.sh",
    "cap:init": "npx cap init Apex com.apexdosing.app --web-dir=.",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:run:ios": "npx cap run ios",
    "cap:run:android": "npx cap run android",
    "build:ios": "npx cap sync ios && npx cap open ios",
    "build:android": "npx cap sync android && npx cap open android"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/core": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/share": "^6.0.2",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1"
  }
}
